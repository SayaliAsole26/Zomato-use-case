# Hugging Face dataset (Phase 1)
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Local cache path (relative to project root)
DATA_CACHE_PATH=data/cache/restaurants.parquet

# Cost tier thresholds (INR for two people): low <= LOW_MAX < medium <= MEDIUM_MAX < high
COST_TIER_LOW_MAX=500
COST_TIER_MEDIUM_MAX=1000

# LLM (Phase 4+) - Groq
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
MAX_CANDIDATES_FOR_LLM=30
MAX_RESULTS=5
