# Vercel — Production (main) environment variables
# Copy these into: Vercel Dashboard → Project → Settings → Environment Variables
# Scope: Production only (also add Preview if you want PR previews to hit Railway)
#
# After saving, redeploy Production — Vite embeds VITE_* at build time.

VITE_API_URL=https://YOUR-RAILWAY-URL.up.railway.app
