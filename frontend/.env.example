# =============================================================================
# Vercel Production (main branch) — required
# Dashboard: Project → Settings → Environment Variables → Production
# =============================================================================
VITE_API_URL=https://YOUR-RAILWAY-URL.up.railway.app
#
# Rules:
# - Use your Railway public URL (no trailing slash)
# - Example: https://culinaai-api-production.up.railway.app
# - Redeploy after changing this value
#
# =============================================================================
# Local dev — leave VITE_API_URL unset; Vite proxies to http://127.0.0.1:8001
# =============================================================================
